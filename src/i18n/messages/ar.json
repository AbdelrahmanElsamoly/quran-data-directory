  "about": {
    "pageTitle": "حول",
    "why": {
      "paragraph1": "أُنشئت RATQ لجمع موارد البرمجيات القرآنية في مكان واحد واضح وسهل الوصول.",
      "paragraph2": "نساعد المطورين والباحثين والناشرين على اكتشاف الأعمال المفيدة، وفهم طرق استخدامها، والمساهمة بموارد تخدم المجتمع بصورة أوسع."
    },
    "whatIs": {
      "title": "ما هي RATQ؟",
      "paragraph1": "RATQ دليل مجتمعي للمكتبات القرآنية وأدوات التطوير ومجموعات البيانات وواجهات البرمجة وأدوات البحث وغيرها من الموارد التقنية. وتوفر لكل مورد مكانا منظما لعرض الوصف والتوثيق والرخصة والإصدار ومعلومات الوصول.",
      "paragraph2Before": "كما تشجع المنصة النشر والمراجعة بعناية من خلال ",
      "paragraph2After": "، لمساعدة المستخدمين على تقييم الدقة والنسبة الصحيحة والجودة التقنية قبل استخدام المورد.",
      "standards": "معايير إتقان"
    },
    "offer": {
      "title": "ماذا توفر RATQ؟",
      "intro": "تدعم المنصة الرحلة كاملة، من اكتشاف المورد إلى نشره والمحافظة على معلوماته.",
      "items": {
        "catalog": {
          "title": "دليل منظم للموارد",
          "description": "اعثر على المكتبات ومجموعات البيانات وواجهات البرمجة وأدوات التطوير والبحث من خلال دليل موحد وقابل للبحث."
        },
        "verification": {
          "title": "معلومات واضحة عن الجودة",
          "description": "راجع التوثيق والرخص والإصدارات والنسبة ومعلومات توثيق إتقان قبل اختيار المورد المناسب."
        },
        "access": {
          "title": "إدارة الوصول للناشرين",
          "description": "يمكن للناشرين إدارة الموارد المقيدة ومراجعة طلبات الوصول والمحافظة على تحديث معلومات مواردهم."
        },
        "community": {
          "title": "ملاحظات المجتمع",
          "description": "تساعد التعليقات والبلاغات والمراجعات على إبراز الموارد المفيدة واكتشاف المعلومات القديمة والجوانب التي تحتاج إلى تحسين."
        },
        "tools": {
          "title": "أدوات للمطورين",
          "description": "تسهل صفحات المطورين ومفاتيح API وروابط التوثيق وتفاصيل التكامل استخدام الموارد في المشاريع الحقيقية."
        }
      }
    },
    "mission": {
      "title": "مهمتنا",
      "description": "تسهيل اكتشاف الموارد التقنية القرآنية الموثوقة وفهمها ونشرها والمحافظة عليها، ودعم التعاون المسؤول بين المطورين والباحثين والناشرين."
    },
    "vision": {
      "title": "رؤيتنا",
      "description": "مجتمع مترابط للتقنية القرآنية تكون فيه الأعمال القيمة ظاهرة وموثقة ومنسوبة إلى أصحابها، ويسهل البناء عليها وتطويرها."
    }
  },
